# ─────────────────────────────────────────────────────────────
# Lumière — environment variables
# Copy this file to `.env.local` and fill in. Never commit .env.local.
# ─────────────────────────────────────────────────────────────

# ── Public site URL (used for Stripe success/cancel redirects) ──
# Local dev: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Razorpay ──
# Get keys from https://dashboard.razorpay.com/app/keys
# Sign up for free at https://razorpay.com
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=your_key_secret_here

# ── Supabase ──
# Create a project at https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Service role key is SECRET — never expose to the client. Used only by
# /api/webhook and /api/bookings on the server.
SUPABASE_SERVICE_ROLE_KEY=eyJ...replace_me

# ── Resend (email confirmations) ──
# https://resend.com → API Keys
# Optional: if not set, booking still works but no email is sent.
RESEND_API_KEY=re_replace_me
RESEND_FROM_EMAIL=Lumière <bookings@lumiere.clinic>

# ── Admin authentication ──
# Set a strong password — this protects /admin
ADMIN_PASSWORD=change-me-to-something-strong
# Random 32+ char string used to sign the admin session cookie.
# Generate one: `openssl rand -hex 32`
ADMIN_AUTH_SECRET=generate-with-openssl-rand-hex-32
